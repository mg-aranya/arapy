# arapy environment configuration
#
# Copy this file to `.env`, then load it into your shell before running arapy:
#
#   set -a
#   source .env
#   set +a
#
# Notes:
# - `.env` is not auto-loaded by arapy itself.
# - Boolean values accept: true/false, 1/0, yes/no, on/off, enabled/disable.
# - Paths may be absolute or relative.

# -----------------------------------------------------------------------------
# Required connection settings
# -----------------------------------------------------------------------------

# ClearPass server hostname or host:port.
ARAPY_SERVER=clearpass.example.com:443

# OAuth client credentials used for API login.
ARAPY_CLIENT_ID=client-id
ARAPY_CLIENT_SECRET=client-secret

# -----------------------------------------------------------------------------
# Optional request / transport settings
# -----------------------------------------------------------------------------

# URL scheme prefix used when building requests.
ARAPY_HTTPS_PREFIX=https://

# Verify TLS certificates for HTTPS requests.
ARAPY_VERIFY_SSL=false

# HTTP timeout in seconds for API requests.
ARAPY_TIMEOUT=15

# OAuth grant type sent to the token endpoint.
ARAPY_GRANT_TYPE=client_credentials

# -----------------------------------------------------------------------------
# Optional output behavior
# -----------------------------------------------------------------------------

# Default output format when not explicitly set on the CLI.
# Supported values depend on the command/output path, but `json` is the safe default.
ARAPY_DATA_FORMAT=json

# Default CSV fieldnames for CSV output, comma-separated.
# Example: id,name,ip_address
# ARAPY_CSV_FIELDNAMES=id,name

# Print response output to the console in addition to writing files where applicable.
ARAPY_CONSOLE=false

# Mask sensitive fields such as passwords and secrets in saved/logged output.
ARAPY_ENCRYPT_SECRETS=true

# -----------------------------------------------------------------------------
# Optional logging settings
# -----------------------------------------------------------------------------

# Application log level.
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
ARAPY_LOG_LEVEL=INFO

# Enable writing application logs to a file.
# If true and ARAPY_LOG_FILE is unset, logs are written to:
#   <ARAPY_APP_LOG_DIR>/arapy.log
# or by default:
#   ~/.local/state/arapy/logs/arapy.log
ARAPY_LOG_TO_FILE=false

# Exact path to the application log file.
# Setting this also enables file logging automatically.
# ARAPY_LOG_FILE=/home/you/.local/state/arapy/logs/arapy.log

# -----------------------------------------------------------------------------
# Optional storage paths
# -----------------------------------------------------------------------------

# Cache directory for the API catalog cache file.
# Default:
#   ${XDG_CACHE_HOME:-~/.cache}/arapy
# ARAPY_CACHE_DIR=/custom/cache/path

# Base state directory for runtime files.
# Default:
#   ${XDG_STATE_HOME:-~/.local/state}/arapy
# ARAPY_STATE_DIR=/custom/state/path

# Directory for command response/output files.
# Default:
#   <ARAPY_STATE_DIR>/responses
# ARAPY_OUT_DIR=/custom/response/output/path

# Directory for application log files.
# Default:
#   <ARAPY_STATE_DIR>/logs
# ARAPY_APP_LOG_DIR=/custom/app/log/path
