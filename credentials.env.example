# arapy profile credentials
#
# Copy this file to:
#   ~/.config/arapy/credentials.env
#
# Keep this file user-specific and do not commit real secrets.

# -----------------------------------------------------------------------------
# Required OAuth credentials per profile
# -----------------------------------------------------------------------------

ARAPY_CLIENT_ID_PROD=prod-client-id
ARAPY_CLIENT_SECRET_PROD=prod-client-secret

ARAPY_CLIENT_ID_DEV=dev-client-id
ARAPY_CLIENT_SECRET_DEV=dev-client-secret

# Legacy aliases are also supported if you prefer username/password naming:
# ARAPY_USERNAME_PROD=prod-client-id
# ARAPY_PASSWORD_PROD=prod-client-secret
# ARAPY_USERNAME_DEV=dev-client-id
# ARAPY_PASSWORD_DEV=dev-client-secret
