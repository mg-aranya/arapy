# netloom profile credentials
#
# Copy this file to:
#   ~/.config/netloom/credentials.env
#
# Keep this file user-specific and do not commit real secrets.

# -----------------------------------------------------------------------------
# Required OAuth credentials per profile
# -----------------------------------------------------------------------------

NETLOOM_CLIENT_ID_PROD=prod-client-id
NETLOOM_CLIENT_SECRET_PROD=prod-client-secret

NETLOOM_CLIENT_ID_DEV=dev-client-id
NETLOOM_CLIENT_SECRET_DEV=dev-client-secret

# Optional aliases if you prefer username/password naming:
# NETLOOM_USERNAME_PROD=prod-client-id
# NETLOOM_PASSWORD_PROD=prod-client-secret
# NETLOOM_USERNAME_DEV=dev-client-id
# NETLOOM_PASSWORD_DEV=dev-client-secret
