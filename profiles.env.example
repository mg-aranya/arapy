# arapy server profile configuration
#
# Copy this file to:
#   ~/.config/arapy/profiles.env
#
# This file contains profile-scoped connection settings and non-secret defaults.
# Secrets should live in `credentials.env`.

# Active profile selected by `arapy server use <profile>`.
ARAPY_ACTIVE_PROFILE=prod

# -----------------------------------------------------------------------------
# Required per-profile connection settings
# -----------------------------------------------------------------------------

ARAPY_SERVER_PROD=clearpass-prod.example.com:443
ARAPY_SERVER_DEV=clearpass-dev.example.com:443

# -----------------------------------------------------------------------------
# Optional per-profile transport and behavior settings
# -----------------------------------------------------------------------------

ARAPY_HTTPS_PREFIX_PROD=https://
ARAPY_HTTPS_PREFIX_DEV=https://

ARAPY_VERIFY_SSL_PROD=true
ARAPY_VERIFY_SSL_DEV=false

ARAPY_TIMEOUT_PROD=15
ARAPY_TIMEOUT_DEV=15

ARAPY_GRANT_TYPE_PROD=client_credentials
ARAPY_GRANT_TYPE_DEV=client_credentials

# Optional direct token overrides.
# ARAPY_API_TOKEN_PROD=your-prod-access-token
# ARAPY_API_TOKEN_DEV=your-dev-access-token

# Optional token-file overrides.
# ARAPY_API_TOKEN_FILE_PROD=/home/you/.config/arapy/prod-token.json
# ARAPY_API_TOKEN_FILE_DEV=/home/you/.config/arapy/dev-token.json

# Optional output defaults.
ARAPY_DATA_FORMAT_PROD=json
ARAPY_DATA_FORMAT_DEV=json

# ARAPY_CSV_FIELDNAMES_PROD=id,name
# ARAPY_CSV_FIELDNAMES_DEV=id,name

ARAPY_CONSOLE_PROD=false
ARAPY_CONSOLE_DEV=false

ARAPY_ENCRYPT_SECRETS_PROD=true
ARAPY_ENCRYPT_SECRETS_DEV=true

# Optional logging defaults.
ARAPY_LOG_LEVEL_PROD=INFO
ARAPY_LOG_LEVEL_DEV=INFO

# Optional storage path overrides remain global and are usually better set as
# plain environment variables if needed:
# ARAPY_CACHE_DIR=/custom/cache/path
# ARAPY_STATE_DIR=/custom/state/path
# ARAPY_OUT_DIR=/custom/response/output/path
# ARAPY_APP_LOG_DIR=/custom/app/log/path
