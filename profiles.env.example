# netloom server profile configuration
#
# Copy this file to:
#   ~/.config/netloom/plugins/clearpass/profiles.env
#
# This file contains profile-scoped connection settings and non-secret defaults.
# Secrets should live in `credentials.env`.
# Use `netloom load clearpass` first so `~/.config/netloom/config.env` points at
# the active plugin.

# Active profile selection for the clearpass plugin.
NETLOOM_ACTIVE_PROFILE=prod

# -----------------------------------------------------------------------------
# Required per-profile connection settings
# -----------------------------------------------------------------------------

NETLOOM_SERVER_PROD=clearpass-prod.example.com:443
NETLOOM_SERVER_DEV=clearpass-dev.example.com:443

# -----------------------------------------------------------------------------
# Optional per-profile transport and behavior settings
# -----------------------------------------------------------------------------

NETLOOM_HTTPS_PREFIX_PROD=https://
NETLOOM_HTTPS_PREFIX_DEV=https://

NETLOOM_VERIFY_SSL_PROD=true
NETLOOM_VERIFY_SSL_DEV=false

NETLOOM_TIMEOUT_PROD=15
NETLOOM_TIMEOUT_DEV=15

NETLOOM_GRANT_TYPE_PROD=client_credentials
NETLOOM_GRANT_TYPE_DEV=client_credentials

# Optional direct token overrides.
# NETLOOM_API_TOKEN_PROD=your-prod-access-token
# NETLOOM_API_TOKEN_DEV=your-dev-access-token

# Optional token-file overrides.
# NETLOOM_API_TOKEN_FILE_PROD=/home/you/.config/netloom/prod-token.json
# NETLOOM_API_TOKEN_FILE_DEV=/home/you/.config/netloom/dev-token.json

# Optional output defaults.
NETLOOM_DATA_FORMAT_PROD=json
NETLOOM_DATA_FORMAT_DEV=json

# NETLOOM_CSV_FIELDNAMES_PROD=id,name
# NETLOOM_CSV_FIELDNAMES_DEV=id,name

NETLOOM_CONSOLE_PROD=false
NETLOOM_CONSOLE_DEV=false

NETLOOM_ENCRYPT_SECRETS_PROD=true
NETLOOM_ENCRYPT_SECRETS_DEV=true

# Optional logging defaults.
NETLOOM_LOG_LEVEL_PROD=INFO
NETLOOM_LOG_LEVEL_DEV=INFO

# Optional storage path overrides remain global and are usually better set as
# plain environment variables if needed:
# NETLOOM_CACHE_DIR=/custom/cache/path
# NETLOOM_STATE_DIR=/custom/state/path
# NETLOOM_OUT_DIR=/custom/response/output/path
# NETLOOM_APP_LOG_DIR=/custom/app/log/path
